SERVICE_SHARED_NETWORK=service-backbone-shared
BACKEND_SHARED_NETWORK=service-backbone-shared
MSA_SHARED_NETWORK=service-backbone-shared

USER_SERVICE_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-user-service:replace-with-git-sha
USER_MYSQL_IMAGE=mysql:8.4

USER_SERVICE_HOST_BIND=127.0.0.1
USER_SERVICE_HOST_PORT=8082

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8082

MYSQL_DATABASE=user_service
MYSQL_USER=user_service
MYSQL_PASSWORD=replace-with-user-mysql-password
MYSQL_ROOT_PASSWORD=replace-with-user-mysql-root-password

SPRING_DATASOURCE_URL=jdbc:mysql://user-mysql:3306/user_service?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=user_service
SPRING_DATASOURCE_PASSWORD=replace-with-user-db-password

USER_SERVICE_BASE_URL=http://user-service:8082
USER_SERVICE_INTERNAL_JWT_ISSUER=auth-service
USER_SERVICE_INTERNAL_JWT_AUDIENCE=user-service
USER_SERVICE_INTERNAL_JWT_SCOPE=internal
USER_SERVICE_INTERNAL_JWT_SECRET=replace-with-auth-to-user-secret
AUTH_JWT_SECRET=replace-with-auth-access-jwt-secret

PLATFORM_GOVERNANCE_ENABLED=true
PLATFORM_GOVERNANCE_AUDIT_ENABLED=true
PLATFORM_GOVERNANCE_AUDIT_SERVICE_NAME=user-service
PLATFORM_GOVERNANCE_AUDIT_ENVIRONMENT=prod

PLATFORM_SECURITY_ENABLED=true
PLATFORM_SECURITY_SERVICE_ROLE_PRESET=API_SERVER
PLATFORM_SECURITY_AUTH_ENABLED=true
PLATFORM_SECURITY_INTERNAL_TOKEN_ENABLED=true

PLATFORM_SECURITY_JWT_ISSUER=api-gateway
PLATFORM_SECURITY_JWT_AUDIENCE=internal-services
PLATFORM_SECURITY_JWT_SECRET=replace-with-gateway-downstream-shared-secret
