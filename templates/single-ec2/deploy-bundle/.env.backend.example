PLATFORM_SECURITY_IP_GUARD_INTERNAL_RULES_1=10.0.0.0/8
PLATFORM_SECURITY_IP_GUARD_INTERNAL_RULES_2=172.16.0.0/12
PLATFORM_SECURITY_IP_GUARD_INTERNAL_RULES_3=192.168.0.0/16
AUTHZ_INTERNAL_JWT_SECRET=replace-with-authz-caller-proof-secret
AUTHZ_INTERNAL_JWT_ISSUER=api-gateway
AUTHZ_INTERNAL_JWT_AUDIENCE=authz-service
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT_MS=1000

MYSQL_DB=authdb
MYSQL_USER=authuser
MYSQL_PASSWORD=replace-with-auth-db-password
MYSQL_ROOT_PASSWORD=replace-with-auth-db-root-password
MYSQL_URL=jdbc:mysql://auth-mysql:3306/authdb?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
USER_SERVICE_BASE_URL=http://user-service:8082
USER_SERVICE_JWT_ISSUER=auth-service
USER_SERVICE_JWT_AUDIENCE=user-service
USER_SERVICE_JWT_SUBJECT=auth-service
USER_SERVICE_JWT_SCOPE=internal
USER_SERVICE_JWT_SECRET=replace-with-auth-to-user-secret
AUTH_JWT_SECRET=replace-with-auth-access-jwt-secret
SSO_GITHUB_CLIENT_ID=replace-with-github-client-id
SSO_GITHUB_CLIENT_SECRET=replace-with-github-client-secret
SSO_GITHUB_CALLBACK_URI=https://api.myeditor.n-e.kr/v1/login/oauth2/code/github
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GITHUB_REDIRECT_URI=https://api.myeditor.n-e.kr/v1/login/oauth2/code/github
SSO_EXPLAIN_ORIGIN=https://myeditor.n-e.kr
SSO_EXPLAIN_CALLBACK_URI=https://myeditor.n-e.kr/auth/callback
