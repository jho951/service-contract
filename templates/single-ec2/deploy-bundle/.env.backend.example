SPRING_DATASOURCE_USERNAME=user_service
SPRING_DATASOURCE_PASSWORD=replace-with-user-db-password
USER_SERVICE_INTERNAL_JWT_ISSUER=auth-service
USER_SERVICE_INTERNAL_JWT_AUDIENCE=user-service
USER_SERVICE_INTERNAL_JWT_SCOPE=internal
USER_SERVICE_INTERNAL_JWT_SECRET=replace-with-auth-to-user-secret
