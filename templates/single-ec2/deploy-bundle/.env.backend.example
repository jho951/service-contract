GATEWAY_INTERNAL_JWT_ISSUER=api-gateway
GATEWAY_INTERNAL_JWT_AUDIENCE=internal-services
PLATFORM_SECURITY_AUTH_JWT_SECRET=replace-with-platform-security-jwt-secret
PLATFORM_SECURITY_IP_GUARD_ENABLED=true
PLATFORM_SECURITY_IP_GUARD_ADMIN_RULES_0=127.0.0.1/32
