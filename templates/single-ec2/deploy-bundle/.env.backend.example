MYSQL_ROOT_PASSWORD_PROD=replace-with-editor-mysql-root-password
DB_NAME_PROD=documentsdb
DB_URL_PROD=jdbc:mysql://editor-mysql:3306/documentsdb?useSSL=false&allowPublicKeyRetrieval=true&useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci&serverTimezone=Asia/Seoul
DB_USERNAME_PROD=documents
DB_PASSWORD_PROD=replace-with-editor-db-password
JWT_SECRET=replace-with-editor-app-jwt-secret
PLATFORM_GOVERNANCE_SERVICE_ROLE_PRESET=RESOURCE_SERVICE
PLATFORM_SECURITY_SERVICE_ROLE_PRESET=API_SERVER
PLATFORM_RESOURCE_ENABLED=true
