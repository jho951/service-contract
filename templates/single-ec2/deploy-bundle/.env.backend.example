SSO_EDITOR_CALLBACK_URI=https://editor.myeditor.n-e.kr/auth/callback
SSO_SESSION_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SECURE=true

MYSQL_DATABASE=user_service
MYSQL_USER_USER_SERVICE=user_service
MYSQL_PASSWORD_USER_SERVICE=replace-with-user-mysql-password
MYSQL_ROOT_PASSWORD_USER_SERVICE=replace-with-user-mysql-root-password
